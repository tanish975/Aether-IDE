# Groq API key for AI chat, code generation, explanations, and debugging.
# Get a key from the Groq Console: https://console.groq.com/
REACT_APP_GROQ_API_KEY=api key

# OneCompiler API key for executing code.
# Direct OneCompiler keys usually start with oc_.
# RapidAPI keys are also supported by the app.
REACT_APP_ONECOMPILER_API_KEY=api  key
